<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="content-wrapper" id="page-content-wrapper">
    <%- include('../partials/navbar') %>
    
    <div class="container-fluid p-4">
        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-edit me-2 text-primary"></i>
                    Input Nilai - <span class="text-primary"><%= laptop.nama_laptop %></span>
                </h5>
            </div>
            <div class="card-body">
                <form action="/nilai/input/<%= laptop.id_laptop %>" method="POST">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Kriteria</th>
                                    <th>Tipe</th>
                                    <th>Bobot</th>
                                    <th>Nilai</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% kriteria.forEach(krit => { %>
                                <tr>
                                    <td><strong><%= krit.nama_kriteria %></strong></td>
                                    <td>
                                        <span class="badge bg-<%= krit.tipe === 'benefit' ? 'success' : 'danger' %>">
                                            <%= krit.tipe %>
                                        </span>
                                    </td>
                                    <td><%= krit.bobot %></td>
                                    <td>
                                        <% 
                                            const existing = nilaiExisting.find(n => n.id_kriteria === krit.id_kriteria);
                                            const existingValue = existing ? existing.nilai : '';
                                        %>
                                        <input type="number" class="form-control" 
                                               name="nilai[<%= krit.id_kriteria %>]" 
                                               value="<%= existingValue %>"
                                               step="0.01" required
                                               placeholder="Masukkan nilai">
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    
                    <hr>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Simpan Nilai
                        </button>
                        <a href="/nilai" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
