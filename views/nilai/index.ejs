<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="content-wrapper" id="page-content-wrapper">
    <%- include('../partials/navbar') %>
    
    <div class="container-fluid p-4">
        <!-- Flash Messages -->
        <% if (success && success.length > 0) { %>
            <script>document.addEventListener('DOMContentLoaded', () => Swal.fire({icon:'success',title:'Berhasil',text:'<%= success %>',timer:3000,showConfirmButton:false}));</script>
        <% } %>
        <% if (error && error.length > 0) { %>
            <script>document.addEventListener('DOMContentLoaded', () => Swal.fire({icon:'error',title:'Error',text:'<%= error %>',timer:3000,showConfirmButton:false}));</script>
        <% } %>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="mb-0 fw-bold"><i class="fas fa-table me-2 text-warning"></i>Data Nilai Laptop</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    Klik tombol "Input Nilai" untuk mengisi/mengubah nilai laptop terhadap kriteria.
                </p>
                
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="dataTable">
                        <thead class="table-light">
                            <tr>
                                <th rowspan="2" class="align-middle text-center">No</th>
                                <th rowspan="2" class="align-middle">Nama Laptop</th>
                                <% kriteria.forEach(krit => { %>
                                    <th class="text-center"><%= krit.nama_kriteria %></th>
                                <% }); %>
                                <th rowspan="2" class="align-middle text-center">Aksi</th>
                            </tr>
                            <tr>
                                <% kriteria.forEach(krit => { %>
                                    <th class="text-center">
                                        <small class="badge bg-<%= krit.tipe === 'benefit' ? 'success' : 'danger' %>"><%= krit.tipe %></small>
                                    </th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% laptops.forEach((laptop, index) => { %>
                            <tr>
                                <td class="text-center"><%= index + 1 %></td>
                                <td><strong><%= laptop.nama_laptop %></strong></td>
                                <% kriteria.forEach(krit => { %>
                                    <td class="text-center">
                                        <% 
                                            const nilaiItem = nilai.find(n => n.id_laptop === laptop.id_laptop && n.id_kriteria === krit.id_kriteria);
                                        %>
                                        <% if (nilaiItem) { %>
                                            <%= parseFloat(nilaiItem.nilai).toLocaleString('id-ID') %>
                                        <% } else { %>
                                            <span class="text-danger">-</span>
                                        <% } %>
                                    </td>
                                <% }); %>
                                <td class="text-center">
                                    <a href="/nilai/input/<%= laptop.id_laptop %>" class="btn btn-primary btn-sm">
                                        <i class="fas fa-edit me-1"></i>Input
                                    </a>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
(function() {
    var table = document.getElementById('dataTable');
    if (table && window.jQuery) {
        if ($.fn.DataTable.isDataTable(table)) {
            $(table).DataTable().destroy();
        }
        $(table).DataTable({
            language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/id.json' },
            paging: false
        });
    }
})();
</script>
