<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="content-wrapper" id="page-content-wrapper">
    <%- include('../partials/navbar') %>
    
    <div class="container-fluid p-4">
        <% if (success && success.length > 0) { %>
            <script>document.addEventListener('DOMContentLoaded', () => Swal.fire({icon:'success',title:'Berhasil',text:'<%= success %>',timer:2000,showConfirmButton:false}));</script>
        <% } %>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i>History Perhitungan TOPSIS</h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" id="btnSaveNow">
                        <i class="fas fa-save me-1"></i> Simpan Hasil Sekarang
                    </button>
                    <% if (histories.length > 0) { %>
                    <a href="#" class="btn btn-danger btn-sm" id="btnClearHistory">
                        <i class="fas fa-trash me-1"></i> Hapus Semua
                    </a>
                    <% } %>
                </div>
            </div>
            <div class="card-body">
                <% if (histories.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-history fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Belum ada history. Klik <strong>Simpan Hasil Sekarang</strong> untuk menyimpan hasil TOPSIS terbaru.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th width="5%">#</th>
                                    <th>Tanggal</th>
                                    <th>Laptop</th>
                                    <th>Kriteria</th>
                                    <th>Pemenang</th>
                                    <th>Nilai Vi</th>
                                    <th width="15%">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% histories.forEach((h, i) => { %>
                                    <tr>
                                        <td><%= i + 1 %></td>
                                        <td><small><%= new Date(h.timestamp).toLocaleString('id-ID') %></small></td>
                                        <td><span class="badge bg-primary"><%= h.total_laptop %></span></td>
                                        <td><span class="badge bg-success"><%= h.total_kriteria %></span></td>
                                        <td><strong class="text-primary"><i class="fas fa-crown me-1 text-warning"></i><%= h.ranking_terbaik %></strong></td>
                                        <td><strong><%= h.nilai_terbaik.toFixed(4) %></strong></td>
                                        <td>
                                            <button class="btn btn-info btn-sm btn-detail" data-detail='<%- JSON.stringify(JSON.parse(h.detail_ranking)) %>' data-tanggal="<%= new Date(h.timestamp).toLocaleString('id-ID') %>" title="Detail">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <a href="/tools/history/delete/<%= h.id %>" class="btn btn-danger btn-sm btn-delete" data-url="/tools/history/delete/<%= h.id %>" data-name="History tanggal <%= new Date(h.timestamp).toLocaleString('id-ID') %>" title="Hapus">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

        <script>
        (function() {
            var isDark = document.body.classList.contains('dark');
            var bg = isDark ? '#1e293b' : '#fff';
            var color = isDark ? '#f1f5f9' : '#1e293b';

            // Save now
            var btnSave = document.getElementById('btnSaveNow');
            if (btnSave) {
                btnSave.addEventListener('click', function() {
                    fetch('/tools/history/save', { method: 'POST' })
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success', title: 'Berhasil!', text: 'Hasil tersimpan ke history',
                                    timer: 1500, showConfirmButton: false,
                                    background: bg, color: color
                                }).then(() => location.reload());
                            } else {
                                Swal.fire({ icon: 'error', title: 'Error', text: data.error, background: bg, color: color });
                            }
                        });
                });
            }

            // Clear history
            var btnClear = document.getElementById('btnClearHistory');
            if (btnClear) {
                btnClear.addEventListener('click', function(e) {
                    e.preventDefault();
                    Swal.fire({
                        title: 'Hapus Semua History?',
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: 'Ya, Hapus', cancelButtonText: 'Batal',
                        background: bg, color: color
                    }).then(r => { if (r.isConfirmed) window.location.href = '/tools/history/clear'; });
                });
            }

            // Detail button
            document.querySelectorAll('.btn-detail').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var detail = JSON.parse(btn.getAttribute('data-detail'));
                    var tanggal = btn.getAttribute('data-tanggal');
                    var html = '<table class="table table-sm"><thead><tr><th>#</th><th>Laptop</th><th>Vi</th></tr></thead><tbody>';
                    detail.forEach(function(d) {
                        html += '<tr><td>' + d.ranking + '</td><td>' + d.nama_laptop + '</td><td>' + d.nilai_preferensi.toFixed(4) + '</td></tr>';
                    });
                    html += '</tbody></table>';
                    Swal.fire({
                        title: 'Detail Ranking',
                        html: '<small class="text-muted">' + tanggal + '</small>' + html,
                        width: 600,
                        background: bg, color: color
                    });
                });
            });
        })();
        </script>
    </div>
</div>

<%- include('../partials/footer') %>
