<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="content-wrapper" id="page-content-wrapper">
    <%- include('../partials/navbar') %>
    
    <div class="container-fluid p-4">
        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="mb-0 fw-bold"><i class="fas fa-plus-circle me-2 text-success"></i>Tambah Kriteria Baru</h5>
            </div>
            <div class="card-body">
                <form action="/kriteria/create" method="POST">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nama Kriteria <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="nama_kriteria" placeholder="Contoh: Layar" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bobot (0-1) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="bobot" id="bobotInput" placeholder="0.10" step="0.01" min="0" max="1" required>
                            <small class="text-muted">Nilai antara 0 dan 1</small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Tipe <span class="text-danger">*</span></label>
                            <select class="form-select" name="tipe" required>
                                <option value="">-- Pilih Tipe --</option>
                                <option value="benefit">Benefit (semakin besar semakin baik)</option>
                                <option value="cost">Cost (semakin kecil semakin baik)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Real-time validator -->
                    <div id="bobotValidator" class="alert alert-info mb-3" style="display:flex;align-items:center;gap:10px;">
                        <i class="fas fa-calculator"></i>
                        <div class="flex-grow-1">
                            <small>Total bobot kriteria saat ini: <strong><%= currentTotal.toFixed(3) %></strong></small><br>
                            <small>Total setelah ditambahkan: <strong id="totalDisplay">-</strong> / 1.000</small>
                        </div>
                        <span class="badge bg-secondary" id="validBadge">-</span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save me-1"></i> Simpan
                        </button>
                        <a href="/kriteria" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <script>
        (function() {
            var currentTotal = <%= currentTotal %>;
            var input = document.getElementById('bobotInput');
            var totalDisplay = document.getElementById('totalDisplay');
            var validBadge = document.getElementById('validBadge');
            var validator = document.getElementById('bobotValidator');

            function updateValidator() {
                var bobot = parseFloat(input.value) || 0;
                var total = currentTotal + bobot;
                totalDisplay.textContent = total.toFixed(3);

                if (Math.abs(total - 1.0) < 0.001 && bobot > 0) {
                    validator.classList.remove('alert-warning', 'alert-info');
                    validator.classList.add('alert-success');
                    validBadge.textContent = 'VALID';
                    validBadge.className = 'badge bg-success';
                } else if (bobot === 0) {
                    validator.classList.remove('alert-success', 'alert-warning');
                    validator.classList.add('alert-info');
                    validBadge.textContent = '-';
                    validBadge.className = 'badge bg-secondary';
                } else {
                    validator.classList.remove('alert-success', 'alert-info');
                    validator.classList.add('alert-warning');
                    var diff = Math.abs(total - 1.0).toFixed(3);
                    validBadge.textContent = total > 1 ? 'Lebih ' + diff : 'Kurang ' + diff;
                    validBadge.className = 'badge bg-warning';
                }
            }

            if (input) {
                input.addEventListener('input', updateValidator);
            }
        })();
        </script>
    </div>
</div>

<%- include('../partials/footer') %>
