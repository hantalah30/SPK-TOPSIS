<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="content-wrapper" id="page-content-wrapper">
    <%- include('../partials/navbar') %>
    
    <div class="container-fluid p-4">
        <!-- Flash Messages -->
        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <% if (!hasil) { %>
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Data belum cukup untuk melakukan perhitungan TOPSIS. Pastikan minimal 2 laptop dan semua nilai sudah diisi.
            </div>
        <% } else { %>

        <!-- Tombol Export -->
        <div class="d-flex justify-content-end mb-3 gap-2">
            <button class="btn btn-success btn-sm" id="btnExportExcel">
                <i class="fas fa-file-excel me-1"></i> Export Excel
            </button>
            <button class="btn btn-danger btn-sm" id="btnExportPDF">
                <i class="fas fa-file-pdf me-1"></i> Export PDF
            </button>
            <button class="btn btn-primary btn-sm" id="btnSaveHistory">
                <i class="fas fa-save me-1"></i> Simpan ke History
            </button>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 1: MATRIKS KEPUTUSAN -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-table me-2"></i>Langkah 1: Matriks Keputusan</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Penjelasan:</strong> Matriks keputusan berisi nilai mentah setiap alternatif terhadap setiap kriteria. Baris pembagi (kuning) adalah <code>√(Σx²)</code> per kolom yang akan digunakan untuk normalisasi di langkah 2.
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Alternatif</th>
                                <% hasil.kriteria.forEach(k => { %>
                                    <th class="text-center"><%= k.nama_kriteria %> (<%= k.tipe %>)</th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% hasil.alternatif.forEach((alt, i) => { %>
                            <tr>
                                <td><strong><%= alt.nama_laptop %></strong></td>
                                <% hasil.matriksKeputusan[i].forEach(val => { %>
                                    <td class="text-center"><%= val.toLocaleString('id-ID') %></td>
                                <% }); %>
                            </tr>
                            <% }); %>
                        </tbody>
                        <tfoot class="table-warning">
                            <tr>
                                <td><strong>Pembagi</strong></td>
                                <% hasil.pembagi.forEach(val => { %>
                                    <td class="text-center"><%= val.toFixed(4) %></td>
                                <% }); %>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 2: MATRIKS NORMALISASI -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-success text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-divide me-2"></i>Langkah 2: Matriks Normalisasi (rij = xij / pembagi)</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Tujuan:</strong> Menyamakan skala semua kriteria (karena harga dalam jutaan, RAM dalam GB, dll). Rumus: <code>rij = xij / √(Σxij²)</code>. Setelah dinormalisasi, semua nilai berada di rentang 0-1.
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Alternatif</th>
                                <% hasil.kriteria.forEach(k => { %>
                                    <th class="text-center"><%= k.nama_kriteria %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% hasil.alternatif.forEach((alt, i) => { %>
                            <tr>
                                <td><strong><%= alt.nama_laptop %></strong></td>
                                <% hasil.matriksNormalisasi[i].forEach(val => { %>
                                    <td class="text-center"><%= val.toFixed(6) %></td>
                                <% }); %>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 3: MATRIKS TERBOBOT -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-info text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-weight-hanging me-2"></i>Langkah 3: Matriks Normalisasi Terbobot (yij = wi × rij)</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Tujuan:</strong> Memberikan pengaruh bobot kepentingan ke setiap kriteria. Kriteria dengan bobot lebih besar akan punya pengaruh lebih besar pada hasil ranking. Rumus: <code>yij = wi × rij</code>.
                </div>
                <p class="text-muted small mb-2">
                    Bobot: <% hasil.kriteria.forEach((k, idx) => { %><%= k.nama_kriteria %> = <%= k.bobot %><%= idx < hasil.kriteria.length - 1 ? ', ' : '' %><% }); %>
                </p>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Alternatif</th>
                                <% hasil.kriteria.forEach(k => { %>
                                    <th class="text-center"><%= k.nama_kriteria %> (w=<%= k.bobot %>)</th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <% hasil.alternatif.forEach((alt, i) => { %>
                            <tr>
                                <td><strong><%= alt.nama_laptop %></strong></td>
                                <% hasil.matriksTerbobot[i].forEach(val => { %>
                                    <td class="text-center"><%= val.toFixed(6) %></td>
                                <% }); %>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 4: SOLUSI IDEAL -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-warning text-dark py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-bullseye me-2"></i>Langkah 4: Solusi Ideal Positif (A+) dan Negatif (A-)</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Penjelasan:</strong> A+ = kondisi terbaik yang mungkin (max untuk benefit, min untuk cost). A- = kondisi terburuk (min untuk benefit, max untuk cost). Konsep TOPSIS: alternatif terbaik adalah yang paling dekat ke A+ dan paling jauh dari A-.
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Solusi Ideal</th>
                                <% hasil.kriteria.forEach(k => { %>
                                    <th class="text-center"><%= k.nama_kriteria %></th>
                                <% }); %>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="table-success">
                                <td><strong>A+ (Positif)</strong></td>
                                <% hasil.solusiIdealPositif.forEach(val => { %>
                                    <td class="text-center"><%= val.toFixed(6) %></td>
                                <% }); %>
                            </tr>
                            <tr class="table-danger">
                                <td><strong>A- (Negatif)</strong></td>
                                <% hasil.solusiIdealNegatif.forEach(val => { %>
                                    <td class="text-center"><%= val.toFixed(6) %></td>
                                <% }); %>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <small class="text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    Benefit: A+ = max, A- = min | Cost: A+ = min, A- = max
                </small>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 5: JARAK D+ DAN D- -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-secondary text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-ruler me-2"></i>Langkah 5: Jarak Solusi Ideal (D+ dan D-)</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Rumus Euclidean:</strong> D+ = √(Σ(yij - A+j)²) untuk jarak ke kondisi terbaik. D- = √(Σ(yij - A-j)²) untuk jarak ke kondisi terburuk. Semakin kecil D+ dan semakin besar D-, semakin baik alternatif tersebut.
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Alternatif</th>
                                <th class="text-center">D+ (Jarak ke A+)</th>
                                <th class="text-center">D- (Jarak ke A-)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% hasil.alternatif.forEach((alt, i) => { %>
                            <tr>
                                <td><strong><%= alt.nama_laptop %></strong></td>
                                <td class="text-center"><%= hasil.jarakPositif[i].toFixed(6) %></td>
                                <td class="text-center"><%= hasil.jarakNegatif[i].toFixed(6) %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ============================================ -->
        <!-- LANGKAH 6 & 7: NILAI PREFERENSI & RANKING -->
        <!-- ============================================ -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-trophy me-2"></i>Langkah 6 & 7: Nilai Preferensi & Ranking Akhir</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info py-2 small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    <strong>Rumus Final:</strong> <code>Vi = D- / (D- + D+)</code>. Nilai Vi berada di rentang 0-1. Semakin besar Vi, semakin baik alternatif. Vi = 1 berarti identik dengan solusi ideal positif, Vi = 0 berarti identik dengan solusi ideal negatif. Ranking diurutkan dari Vi terbesar.
                </div>
                <p class="text-muted mb-3">
                    <strong>Rumus:</strong> Vi = D- / (D- + D+) → Semakin besar Vi, semakin baik alternatif tersebut.
                </p>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center">Ranking</th>
                                <th>Nama Laptop</th>
                                <th class="text-center">D+</th>
                                <th class="text-center">D-</th>
                                <th class="text-center">Nilai Preferensi (Vi)</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% hasil.ranking.forEach((item, index) => { %>
                            <tr class="<%= index === 0 ? 'table-success fw-bold' : '' %>">
                                <td class="text-center">
                                    <% if (index === 0) { %>
                                        <span class="badge bg-warning text-dark fs-6"><i class="fas fa-crown me-1"></i><%= item.ranking %></span>
                                    <% } else { %>
                                        <span class="badge bg-secondary"><%= item.ranking %></span>
                                    <% } %>
                                </td>
                                <td>
                                    <%= item.nama_laptop %>
                                    <% if (index === 0) { %>
                                        <span class="badge bg-success ms-2">TERBAIK</span>
                                    <% } %>
                                </td>
                                <td class="text-center"><%= item.jarak_positif.toFixed(6) %></td>
                                <td class="text-center"><%= item.jarak_negatif.toFixed(6) %></td>
                                <td class="text-center"><strong><%= item.nilai_preferensi.toFixed(6) %></strong></td>
                                <td class="text-center">
                                    <% if (index === 0) { %>
                                        <span class="badge bg-success"><i class="fas fa-star me-1"></i>Ranking 1</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark">Ranking <%= item.ranking %></span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Kesimpulan -->
                <div class="alert alert-success mt-4">
                    <h5 class="alert-heading"><i class="fas fa-check-circle me-2"></i>Kesimpulan</h5>
                    <p class="mb-0">
                        Berdasarkan perhitungan metode TOPSIS, laptop terbaik adalah 
                        <strong class="text-primary"><%= hasil.ranking[0].nama_laptop %></strong> 
                        dengan nilai preferensi <strong><%= hasil.ranking[0].nilai_preferensi.toFixed(6) %></strong>.
                    </p>
                </div>
            </div>
        </div>

        <!-- Chart Ranking -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-3">
                <h6 class="mb-0 fw-bold"><i class="fas fa-chart-bar me-2 text-primary"></i>Grafik Nilai Preferensi</h6>
            </div>
            <div class="card-body" style="height:320px;">
                <canvas id="rankingChart"></canvas>
            </div>
        </div>

        <script>
        (function() {
            function initChart() {
                const canvas = document.getElementById('rankingChart');
                if (!canvas || typeof Chart === 'undefined') {
                    return setTimeout(initChart, 50);
                }
                const ranking = <%- JSON.stringify(hasil.ranking) %>;
                const isDark = document.body.classList.contains('dark');
                const textColor = isDark ? '#cbd5e1' : '#334155';
                const mutedColor = isDark ? '#94a3b8' : '#64748b';
                const gridColor = isDark ? 'rgba(255,255,255,0.04)' : 'rgba(15,23,42,0.06)';

                const ctx = canvas.getContext('2d');

                function gradient(color1, color2) {
                    const g = ctx.createLinearGradient(0, 0, 0, canvas.height);
                    g.addColorStop(0, color1);
                    g.addColorStop(1, color2);
                    return g;
                }

                Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";
                Chart.defaults.font.size = 12;

                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ranking.map(r => r.nama_laptop),
                        datasets: [{
                            label: 'Nilai Preferensi (Vi)',
                            data: ranking.map(r => r.nilai_preferensi),
                            backgroundColor: ranking.map((r, i) => i === 0
                                ? gradient('rgba(34, 197, 94, 1)', 'rgba(34, 197, 94, 0.5)')
                                : gradient('rgba(99, 102, 241, 0.95)', 'rgba(99, 102, 241, 0.5)')),
                            borderRadius: 12,
                            borderSkipped: false,
                            barPercentage: 0.6,
                            categoryPercentage: 0.85
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 1000,
                            easing: 'easeOutQuart',
                            delay: (ctx) => ctx.type === 'data' ? ctx.dataIndex * 80 : 0
                        },
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: isDark ? 'rgba(15, 23, 42, 0.95)' : 'rgba(255, 255, 255, 0.98)',
                                titleColor: isDark ? '#f1f5f9' : '#1e293b',
                                bodyColor: isDark ? '#cbd5e1' : '#475569',
                                borderColor: isDark ? '#334155' : '#e2e8f0',
                                borderWidth: 1,
                                padding: 12,
                                cornerRadius: 10,
                                titleFont: { weight: '700', size: 13 },
                                bodyFont: { size: 12 },
                                callbacks: {
                                    label: (c) => '  Vi: ' + c.parsed.y.toFixed(6)
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 1,
                                grid: { color: gridColor, drawBorder: false },
                                border: { display: false },
                                ticks: { color: mutedColor, padding: 10, font: { size: 11 } },
                                title: { display: true, text: 'Nilai Preferensi', color: mutedColor, font: { size: 12, weight: '600' }, padding: { bottom: 10 } }
                            },
                            x: {
                                grid: { display: false },
                                border: { display: false },
                                ticks: { color: mutedColor, padding: 8, font: { size: 11, weight: '500' } }
                            }
                        }
                    }
                });
            }
            requestAnimationFrame(initChart);
        })();
        </script>

        <!-- Export & History Logic -->
        <script>
        (function() {
            var hasil = <%- JSON.stringify(hasil) %>;
            
            function getDarkBg() { return document.body.classList.contains('dark') ? '#1e293b' : '#fff'; }
            function getDarkColor() { return document.body.classList.contains('dark') ? '#f1f5f9' : '#1e293b'; }

            function showError(msg) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: 'error', title: 'Error', text: msg, background: getDarkBg(), color: getDarkColor() });
                } else {
                    alert(msg);
                }
            }

            function showSuccess(msg) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: 'success', title: 'Berhasil', text: msg, timer: 2000, showConfirmButton: false, background: getDarkBg(), color: getDarkColor() });
                }
            }

            // ============================================
            // EXPORT EXCEL (RAPI dengan styling)
            // ============================================
            function exportExcel() {
                if (typeof XLSX === 'undefined') {
                    showError('Library Excel belum siap. Tunggu sebentar lalu coba lagi.');
                    return;
                }

                try {
                    var wb = XLSX.utils.book_new();
                    var tanggal = new Date().toLocaleString('id-ID', { dateStyle: 'full', timeStyle: 'short' });
                    var winner = hasil.ranking[0];

                    // ===== SHEET 1: RINGKASAN =====
                    var ringkasan = [
                        ['LAPORAN PERHITUNGAN TOPSIS'],
                        ['SPK Pemilihan Laptop Terbaik'],
                        [''],
                        ['Tanggal Cetak', tanggal],
                        ['Total Alternatif', hasil.alternatif.length],
                        ['Total Kriteria', hasil.kriteria.length],
                        [''],
                        ['HASIL: LAPTOP TERBAIK'],
                        ['Nama', winner.nama_laptop],
                        ['Nilai Preferensi (Vi)', winner.nilai_preferensi.toFixed(6)],
                        ['Jarak ke Solusi Ideal Positif (D+)', winner.jarak_positif.toFixed(6)],
                        ['Jarak ke Solusi Ideal Negatif (D-)', winner.jarak_negatif.toFixed(6)]
                    ];
                    var wsRingkasan = XLSX.utils.aoa_to_sheet(ringkasan);
                    wsRingkasan['!cols'] = [{ wch: 35 }, { wch: 35 }];
                    // Merge cells untuk title
                    wsRingkasan['!merges'] = [
                        { s: { r: 0, c: 0 }, e: { r: 0, c: 1 } },
                        { s: { r: 1, c: 0 }, e: { r: 1, c: 1 } },
                        { s: { r: 7, c: 0 }, e: { r: 7, c: 1 } }
                    ];
                    XLSX.utils.book_append_sheet(wb, wsRingkasan, 'Ringkasan');

                    // ===== SHEET 2: RANKING =====
                    var rankingHeader = ['Ranking', 'Nama Laptop', 'D+', 'D-', 'Nilai Preferensi (Vi)', 'Status'];
                    var rankingRows = hasil.ranking.map(function(r, i) {
                        return [
                            r.ranking,
                            r.nama_laptop,
                            parseFloat(r.jarak_positif.toFixed(6)),
                            parseFloat(r.jarak_negatif.toFixed(6)),
                            parseFloat(r.nilai_preferensi.toFixed(6)),
                            i === 0 ? 'TERBAIK' : ''
                        ];
                    });
                    var wsRanking = XLSX.utils.aoa_to_sheet([rankingHeader].concat(rankingRows));
                    wsRanking['!cols'] = [{ wch: 10 }, { wch: 30 }, { wch: 14 }, { wch: 14 }, { wch: 22 }, { wch: 12 }];
                    XLSX.utils.book_append_sheet(wb, wsRanking, 'Ranking Akhir');

                    // ===== SHEET 3: DATA LAPTOP =====
                    var laptopHeader = ['No', 'Nama Laptop', 'Harga (Rp)', 'RAM (GB)', 'SSD (GB)', 'Baterai (Jam)', 'Processor', 'Skor Proc', 'GPU', 'Skor GPU', 'Upgrade RAM', 'Upgrade Storage'];
                    var laptopRows = hasil.alternatif.map(function(alt, i) {
                        return [
                            i + 1,
                            alt.nama_laptop,
                            alt.harga,
                            alt.ram,
                            alt.ssd,
                            alt.baterai,
                            alt.processor || '-',
                            alt.skor_processor || 5,
                            alt.gpu || '-',
                            alt.skor_gpu || 5,
                            alt.upgrade_ram ? 'Ya' : 'Tidak',
                            alt.upgrade_storage ? 'Ya' : 'Tidak'
                        ];
                    });
                    var wsLaptop = XLSX.utils.aoa_to_sheet([laptopHeader].concat(laptopRows));
                    wsLaptop['!cols'] = [{ wch: 5 }, { wch: 25 }, { wch: 14 }, { wch: 10 }, { wch: 10 }, { wch: 12 }, { wch: 25 }, { wch: 10 }, { wch: 25 }, { wch: 10 }, { wch: 12 }, { wch: 14 }];
                    XLSX.utils.book_append_sheet(wb, wsLaptop, 'Data Laptop');

                    // ===== SHEET 4: DATA KRITERIA =====
                    var kriteriaHeader = ['No', 'Kode', 'Nama Kriteria', 'Bobot', 'Tipe'];
                    var kriteriaRows = hasil.kriteria.map(function(k, i) {
                        return [i + 1, 'C' + (i + 1), k.nama_kriteria, parseFloat(k.bobot), k.tipe];
                    });
                    var totalBobot = hasil.kriteria.reduce(function(s, k) { return s + parseFloat(k.bobot); }, 0);
                    kriteriaRows.push(['', '', 'TOTAL BOBOT', parseFloat(totalBobot.toFixed(4)), '']);
                    var wsKriteria = XLSX.utils.aoa_to_sheet([kriteriaHeader].concat(kriteriaRows));
                    wsKriteria['!cols'] = [{ wch: 5 }, { wch: 8 }, { wch: 25 }, { wch: 12 }, { wch: 12 }];
                    XLSX.utils.book_append_sheet(wb, wsKriteria, 'Data Kriteria');

                    // ===== SHEET 5: MATRIKS KEPUTUSAN =====
                    var mkSheetName = '1.Matriks Keputusan';
                    var mkHeader = ['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria + ' [' + k.tipe + ']'; }));
                    var mkRows = hasil.alternatif.map(function(alt, i) {
                        return [alt.nama_laptop].concat(hasil.matriksKeputusan[i]);
                    });
                    // Baris pembagi pakai FORMULA SQRT(SUMSQ(...))
                    var pembagiFmRow = ['Pembagi (√Σx²)'];
                    var nAlt = hasil.alternatif.length;
                    var nKrit = hasil.kriteria.length;
                    for (var j = 0; j < nKrit; j++) {
                        var colLetter = XLSX.utils.encode_col(j + 1);
                        var startRow = 2; // row 1 = header, row 2 = first data
                        var endRow = startRow + nAlt - 1;
                        pembagiFmRow.push({ f: 'SQRT(SUMSQ(' + colLetter + startRow + ':' + colLetter + endRow + '))' });
                    }
                    var allMkRows = [mkHeader].concat(mkRows).concat([pembagiFmRow]);
                    var wsMK = XLSX.utils.aoa_to_sheet(allMkRows);
                    wsMK['!cols'] = [{ wch: 25 }].concat(hasil.kriteria.map(function() { return { wch: 18 }; }));
                    XLSX.utils.book_append_sheet(wb, wsMK, mkSheetName);

                    // ===== SHEET 6: NORMALISASI (DENGAN FORMULA) =====
                    var normHeader = ['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria; }));
                    var normRows = [];
                    for (var i = 0; i < nAlt; i++) {
                        var row = [hasil.alternatif[i].nama_laptop];
                        for (var j = 0; j < nKrit; j++) {
                            var colLetter = XLSX.utils.encode_col(j + 1);
                            var dataRow = i + 2; // row in MK sheet (1-indexed, +1 for header)
                            var pembRow = nAlt + 2; // pembagi row in MK sheet
                            // Formula: ='1.Matriks Keputusan'!B2 / '1.Matriks Keputusan'!B7
                            var mkRef = "'" + mkSheetName + "'!" + colLetter;
                            row.push({ f: mkRef + dataRow + '/' + mkRef + pembRow, v: hasil.matriksNormalisasi[i][j] });
                        }
                        normRows.push(row);
                    }
                    var wsNorm = XLSX.utils.aoa_to_sheet([normHeader].concat(normRows));
                    wsNorm['!cols'] = [{ wch: 25 }].concat(hasil.kriteria.map(function() { return { wch: 14 }; }));
                    XLSX.utils.book_append_sheet(wb, wsNorm, '2.Normalisasi');

                    // ===== SHEET 7: TERBOBOT (DENGAN FORMULA) =====
                    var tbHeader = ['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria + ' (w=' + k.bobot + ')'; }));
                    var tbRows = [];
                    for (var i = 0; i < nAlt; i++) {
                        var row = [hasil.alternatif[i].nama_laptop];
                        for (var j = 0; j < nKrit; j++) {
                            var colLetter = XLSX.utils.encode_col(j + 1);
                            var normRow = i + 2;
                            var bobot = parseFloat(hasil.kriteria[j].bobot);
                            // Formula: ='2.Normalisasi'!B2 * 0.20
                            row.push({ f: "'2.Normalisasi'!" + colLetter + normRow + '*' + bobot, v: hasil.matriksTerbobot[i][j] });
                        }
                        tbRows.push(row);
                    }
                    var wsTB = XLSX.utils.aoa_to_sheet([tbHeader].concat(tbRows));
                    wsTB['!cols'] = [{ wch: 25 }].concat(hasil.kriteria.map(function() { return { wch: 18 }; }));
                    XLSX.utils.book_append_sheet(wb, wsTB, '3.Terbobot');

                    // ===== SHEET 8: SOLUSI IDEAL (DENGAN FORMULA) =====
                    var idealHeader = ['Solusi'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria + ' [' + k.tipe + ']'; }));
                    var idealPosRow = ['A+ (Solusi Ideal Positif)'];
                    var idealNegRow = ['A- (Solusi Ideal Negatif)'];
                    for (var j = 0; j < nKrit; j++) {
                        var colLetter = XLSX.utils.encode_col(j + 1);
                        var rangeStart = colLetter + '2';
                        var rangeEnd = colLetter + (nAlt + 1);
                        var tbRange = "'3.Terbobot'!" + rangeStart + ':' + "'3.Terbobot'!" + rangeEnd;
                        if (hasil.kriteria[j].tipe === 'benefit') {
                            idealPosRow.push({ f: "MAX('3.Terbobot'!" + rangeStart + ":'3.Terbobot'!" + rangeEnd + ")", v: hasil.solusiIdealPositif[j] });
                            idealNegRow.push({ f: "MIN('3.Terbobot'!" + rangeStart + ":'3.Terbobot'!" + rangeEnd + ")", v: hasil.solusiIdealNegatif[j] });
                        } else {
                            idealPosRow.push({ f: "MIN('3.Terbobot'!" + rangeStart + ":'3.Terbobot'!" + rangeEnd + ")", v: hasil.solusiIdealPositif[j] });
                            idealNegRow.push({ f: "MAX('3.Terbobot'!" + rangeStart + ":'3.Terbobot'!" + rangeEnd + ")", v: hasil.solusiIdealNegatif[j] });
                        }
                    }
                    var wsIdeal = XLSX.utils.aoa_to_sheet([idealHeader, idealPosRow, idealNegRow]);
                    wsIdeal['!cols'] = [{ wch: 30 }].concat(hasil.kriteria.map(function() { return { wch: 18 }; }));
                    XLSX.utils.book_append_sheet(wb, wsIdeal, '4.Solusi Ideal');

                    // ===== SHEET 9: JARAK & PREFERENSI (DENGAN FORMULA) =====
                    var jarakHeader = ['Alternatif', 'Jarak D+ (ke A+)', 'Jarak D- (ke A-)', 'D+ + D-', 'Vi = D-/(D-+D+)', 'Ranking'];
                    var jarakRows = [];
                    for (var i = 0; i < nAlt; i++) {
                        var altRow = i + 2; // row in terbobot sheet
                        // Build SQRT(SUMPRODUCT((terbobot - ideal)^2)) formula
                        var dpParts = [];
                        var dnParts = [];
                        for (var j = 0; j < nKrit; j++) {
                            var colLetter = XLSX.utils.encode_col(j + 1);
                            var tbCell = "'3.Terbobot'!" + colLetter + altRow;
                            var idealPosCell = "'4.Solusi Ideal'!" + colLetter + '2';
                            var idealNegCell = "'4.Solusi Ideal'!" + colLetter + '3';
                            dpParts.push('(' + tbCell + '-' + idealPosCell + ')^2');
                            dnParts.push('(' + tbCell + '-' + idealNegCell + ')^2');
                        }
                        var dpFormula = 'SQRT(' + dpParts.join('+') + ')';
                        var dnFormula = 'SQRT(' + dnParts.join('+') + ')';
                        var rowNum = i + 2; // row in this sheet
                        var viFormula = 'C' + rowNum + '/(C' + rowNum + '+B' + rowNum + ')';
                        var rankFormula = 'RANK(E' + rowNum + ',E$2:E$' + (nAlt + 1) + ',0)';

                        jarakRows.push([
                            hasil.alternatif[i].nama_laptop,
                            { f: dpFormula, v: hasil.jarakPositif[i] },
                            { f: dnFormula, v: hasil.jarakNegatif[i] },
                            { f: 'B' + rowNum + '+C' + rowNum, v: hasil.jarakPositif[i] + hasil.jarakNegatif[i] },
                            { f: viFormula, v: hasil.nilaiPreferensi[i] },
                            { f: rankFormula, v: hasil.ranking.find(function(r) { return r.id_laptop === hasil.alternatif[i].id_laptop; }).ranking }
                        ]);
                    }
                    var wsJarak = XLSX.utils.aoa_to_sheet([jarakHeader].concat(jarakRows));
                    wsJarak['!cols'] = [{ wch: 25 }, { wch: 18 }, { wch: 18 }, { wch: 14 }, { wch: 18 }, { wch: 10 }];
                    XLSX.utils.book_append_sheet(wb, wsJarak, '5.Jarak & Preferensi');

                    var fileName = 'SPK_TOPSIS_' + new Date().toISOString().slice(0,10).replace(/-/g,'') + '_' + new Date().getHours() + new Date().getMinutes() + '.xlsx';
                    
                    // Generate file as binary array, lalu download manual via blob
                    var wbout = XLSX.write(wb, { bookType: 'xlsx', type: 'array' });
                    var blob = new Blob([wbout], { type: 'application/octet-stream' });
                    var url = URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = url;
                    a.download = fileName;
                    document.body.appendChild(a);
                    a.click();
                    setTimeout(function() {
                        document.body.removeChild(a);
                        URL.revokeObjectURL(url);
                    }, 100);
                    
                    showSuccess('Excel berhasil di-download: ' + fileName);
                } catch (err) {
                    console.error(err);
                    showError('Gagal export Excel: ' + err.message);
                }
            }

            // ============================================
            // EXPORT PDF (RAPI dengan layout profesional)
            // ============================================
            function exportPDF() {
                if (typeof window.jspdf === 'undefined' || !window.jspdf.jsPDF) {
                    showError('Library PDF belum siap. Tunggu sebentar lalu coba lagi.');
                    return;
                }

                try {
                    var jsPDF = window.jspdf.jsPDF;
                    var doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
                    var pageW = doc.internal.pageSize.getWidth();
                    var pageH = doc.internal.pageSize.getHeight();
                    var margin = 14;
                    var y = margin;
                    var winner = hasil.ranking[0];

                    // ===== HEADER =====
                    // Background bar
                    doc.setFillColor(79, 110, 247);
                    doc.rect(0, 0, pageW, 30, 'F');
                    
                    // Title
                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(18);
                    doc.setTextColor(255, 255, 255);
                    doc.text('LAPORAN PERHITUNGAN TOPSIS', pageW / 2, 12, { align: 'center' });
                    
                    doc.setFontSize(11);
                    doc.setFont('helvetica', 'normal');
                    doc.text('Sistem Pendukung Keputusan Pemilihan Laptop Terbaik', pageW / 2, 19, { align: 'center' });
                    
                    doc.setFontSize(9);
                    doc.text('Dicetak: ' + new Date().toLocaleString('id-ID', { dateStyle: 'full', timeStyle: 'short' }), pageW / 2, 25, { align: 'center' });
                    
                    y = 38;

                    // ===== KESIMPULAN BOX =====
                    doc.setFillColor(220, 252, 231);
                    doc.setDrawColor(34, 197, 94);
                    doc.setLineWidth(0.5);
                    doc.roundedRect(margin, y, pageW - margin * 2, 24, 2, 2, 'FD');
                    
                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(11);
                    doc.setTextColor(21, 128, 61);
                    doc.text('KESIMPULAN: LAPTOP TERBAIK', margin + 4, y + 6);
                    
                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(14);
                    doc.setTextColor(20, 20, 20);
                    doc.text(winner.nama_laptop, margin + 4, y + 13);
                    
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(9);
                    doc.setTextColor(80, 80, 80);
                    doc.text('Nilai Preferensi (Vi): ' + winner.nilai_preferensi.toFixed(6) + 
                             '   |   D+: ' + winner.jarak_positif.toFixed(4) + 
                             '   |   D-: ' + winner.jarak_negatif.toFixed(4), margin + 4, y + 20);
                    
                    y += 32;

                    // ===== INFO BOX =====
                    doc.setFontSize(9);
                    doc.setTextColor(80, 80, 80);
                    doc.text('Total Alternatif: ' + hasil.alternatif.length + '   |   Total Kriteria: ' + hasil.kriteria.length, margin, y);
                    y += 6;

                    // Helper function for section title
                    function sectionTitle(text, color) {
                        if (y > pageH - 40) { doc.addPage(); y = margin; }
                        color = color || [79, 110, 247];
                        doc.setFillColor(color[0], color[1], color[2]);
                        doc.rect(margin, y, pageW - margin * 2, 7, 'F');
                        doc.setFont('helvetica', 'bold');
                        doc.setFontSize(10);
                        doc.setTextColor(255, 255, 255);
                        doc.text(text, margin + 3, y + 5);
                        y += 9;
                    }

                    // ===== SECTION 1: RANKING =====
                    sectionTitle('1. RANKING AKHIR', [79, 110, 247]);
                    doc.autoTable({
                        startY: y,
                        head: [['Ranking', 'Nama Laptop', 'D+', 'D-', 'Vi', 'Status']],
                        body: hasil.ranking.map(function(r, i) {
                            return [
                                r.ranking,
                                r.nama_laptop,
                                r.jarak_positif.toFixed(6),
                                r.jarak_negatif.toFixed(6),
                                r.nilai_preferensi.toFixed(6),
                                i === 0 ? 'TERBAIK' : ''
                            ];
                        }),
                        theme: 'grid',
                        headStyles: { fillColor: [79, 110, 247], textColor: 255, fontStyle: 'bold', fontSize: 9 },
                        styles: { fontSize: 9, cellPadding: 2 },
                        alternateRowStyles: { fillColor: [248, 250, 252] },
                        didParseCell: function(data) {
                            if (data.section === 'body' && data.row.index === 0) {
                                data.cell.styles.fillColor = [220, 252, 231];
                                data.cell.styles.fontStyle = 'bold';
                            }
                        }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 2: DATA KRITERIA =====
                    sectionTitle('2. DATA KRITERIA', [16, 185, 129]);
                    var totalBobot = hasil.kriteria.reduce(function(s, k) { return s + parseFloat(k.bobot); }, 0);
                    doc.autoTable({
                        startY: y,
                        head: [['Kode', 'Nama Kriteria', 'Bobot', 'Tipe']],
                        body: hasil.kriteria.map(function(k, i) {
                            return ['C' + (i + 1), k.nama_kriteria, k.bobot, k.tipe.toUpperCase()];
                        }).concat([['', 'TOTAL', totalBobot.toFixed(4), '']]),
                        theme: 'grid',
                        headStyles: { fillColor: [16, 185, 129], textColor: 255, fontStyle: 'bold', fontSize: 9 },
                        styles: { fontSize: 9, cellPadding: 2 },
                        alternateRowStyles: { fillColor: [240, 253, 244] }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 3: MATRIKS KEPUTUSAN =====
                    sectionTitle('3. MATRIKS KEPUTUSAN', [99, 102, 241]);
                    var mkHead = ['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria; }));
                    var mkBody = hasil.alternatif.map(function(alt, i) {
                        return [alt.nama_laptop].concat(hasil.matriksKeputusan[i].map(function(v) { return v.toLocaleString('id-ID'); }));
                    });
                    mkBody.push(['Pembagi'].concat(hasil.pembagi.map(function(v) { return v.toFixed(4); })));
                    doc.autoTable({
                        startY: y, head: [mkHead], body: mkBody,
                        theme: 'grid',
                        headStyles: { fillColor: [99, 102, 241], textColor: 255, fontStyle: 'bold', fontSize: 8 },
                        styles: { fontSize: 8, cellPadding: 1.5 },
                        alternateRowStyles: { fillColor: [248, 250, 252] }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 4: NORMALISASI =====
                    if (y > pageH - 40) { doc.addPage(); y = margin; }
                    sectionTitle('4. MATRIKS NORMALISASI (rij = xij / pembagi)', [34, 197, 94]);
                    doc.autoTable({
                        startY: y,
                        head: [['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria; }))],
                        body: hasil.alternatif.map(function(alt, i) {
                            return [alt.nama_laptop].concat(hasil.matriksNormalisasi[i].map(function(v) { return v.toFixed(4); }));
                        }),
                        theme: 'grid',
                        headStyles: { fillColor: [34, 197, 94], textColor: 255, fontStyle: 'bold', fontSize: 8 },
                        styles: { fontSize: 8, cellPadding: 1.5 },
                        alternateRowStyles: { fillColor: [240, 253, 244] }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 5: TERBOBOT =====
                    if (y > pageH - 40) { doc.addPage(); y = margin; }
                    sectionTitle('5. MATRIKS NORMALISASI TERBOBOT (yij = wi x rij)', [6, 182, 212]);
                    doc.autoTable({
                        startY: y,
                        head: [['Alternatif'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria + ' (' + k.bobot + ')'; }))],
                        body: hasil.alternatif.map(function(alt, i) {
                            return [alt.nama_laptop].concat(hasil.matriksTerbobot[i].map(function(v) { return v.toFixed(4); }));
                        }),
                        theme: 'grid',
                        headStyles: { fillColor: [6, 182, 212], textColor: 255, fontStyle: 'bold', fontSize: 8 },
                        styles: { fontSize: 8, cellPadding: 1.5 },
                        alternateRowStyles: { fillColor: [236, 254, 255] }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 6: SOLUSI IDEAL =====
                    if (y > pageH - 40) { doc.addPage(); y = margin; }
                    sectionTitle('6. SOLUSI IDEAL POSITIF (A+) DAN NEGATIF (A-)', [234, 179, 8]);
                    doc.autoTable({
                        startY: y,
                        head: [['Solusi'].concat(hasil.kriteria.map(function(k) { return k.nama_kriteria; }))],
                        body: [
                            ['A+ Positif'].concat(hasil.solusiIdealPositif.map(function(v) { return v.toFixed(4); })),
                            ['A- Negatif'].concat(hasil.solusiIdealNegatif.map(function(v) { return v.toFixed(4); }))
                        ],
                        theme: 'grid',
                        headStyles: { fillColor: [234, 179, 8], textColor: 255, fontStyle: 'bold', fontSize: 8 },
                        styles: { fontSize: 8, cellPadding: 2, fontStyle: 'bold' },
                        didParseCell: function(data) {
                            if (data.section === 'body') {
                                if (data.row.index === 0) data.cell.styles.fillColor = [254, 249, 195];
                                else data.cell.styles.fillColor = [254, 226, 226];
                            }
                        }
                    });
                    y = doc.lastAutoTable.finalY + 6;

                    // ===== SECTION 7: JARAK =====
                    if (y > pageH - 40) { doc.addPage(); y = margin; }
                    sectionTitle('7. JARAK SOLUSI IDEAL & NILAI PREFERENSI', [168, 85, 247]);
                    doc.autoTable({
                        startY: y,
                        head: [['Alternatif', 'D+', 'D-', 'D+ + D-', 'Vi', 'Rank']],
                        body: hasil.alternatif.map(function(alt, i) {
                            var dp = hasil.jarakPositif[i];
                            var dn = hasil.jarakNegatif[i];
                            var vi = hasil.nilaiPreferensi[i];
                            var rank = hasil.ranking.find(function(r) { return r.id_laptop === alt.id_laptop; });
                            return [
                                alt.nama_laptop,
                                dp.toFixed(6),
                                dn.toFixed(6),
                                (dp + dn).toFixed(6),
                                vi.toFixed(6),
                                rank ? rank.ranking : '-'
                            ];
                        }),
                        theme: 'grid',
                        headStyles: { fillColor: [168, 85, 247], textColor: 255, fontStyle: 'bold', fontSize: 8 },
                        styles: { fontSize: 8, cellPadding: 1.5 },
                        alternateRowStyles: { fillColor: [250, 245, 255] }
                    });

                    // ===== FOOTER (semua halaman) =====
                    var pageCount = doc.internal.getNumberOfPages();
                    for (var i = 1; i <= pageCount; i++) {
                        doc.setPage(i);
                        // Garis footer
                        doc.setDrawColor(200, 200, 200);
                        doc.setLineWidth(0.2);
                        doc.line(margin, pageH - 13, pageW - margin, pageH - 13);
                        
                        doc.setFontSize(8);
                        doc.setTextColor(120, 120, 120);
                        doc.setFont('helvetica', 'normal');
                        doc.text('SPK TOPSIS - Pemilihan Laptop Terbaik', margin, pageH - 8);
                        doc.text('Halaman ' + i + ' dari ' + pageCount, pageW - margin, pageH - 8, { align: 'right' });
                    }

                    var fileName = 'SPK_TOPSIS_' + new Date().toISOString().slice(0,10).replace(/-/g,'') + '.pdf';
                    
                    // Use blob download for stability in Electron
                    var pdfBlob = doc.output('blob');
                    var pdfUrl = URL.createObjectURL(pdfBlob);
                    var pdfLink = document.createElement('a');
                    pdfLink.href = pdfUrl;
                    pdfLink.download = fileName;
                    document.body.appendChild(pdfLink);
                    pdfLink.click();
                    setTimeout(function() {
                        document.body.removeChild(pdfLink);
                        URL.revokeObjectURL(pdfUrl);
                    }, 100);
                    
                    showSuccess('PDF berhasil di-download: ' + fileName);
                } catch (err) {
                    console.error(err);
                    showError('Gagal export PDF: ' + err.message);
                }
            }

            // ============================================
            // SAVE TO HISTORY
            // ============================================
            function saveHistory() {
                fetch('/tools/history/save', { method: 'POST' })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.success) showSuccess('Hasil disimpan ke history');
                        else showError(data.error || 'Gagal simpan history');
                    })
                    .catch(function(err) { showError(err.message); });
            }

            // ============================================
            // BIND BUTTONS
            // ============================================
            var btnExcel = document.getElementById('btnExportExcel');
            if (btnExcel) btnExcel.addEventListener('click', exportExcel);

            var btnPDF = document.getElementById('btnExportPDF');
            if (btnPDF) btnPDF.addEventListener('click', exportPDF);

            var btnSave = document.getElementById('btnSaveHistory');
            if (btnSave) btnSave.addEventListener('click', saveHistory);
        })();
        </script>

        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
